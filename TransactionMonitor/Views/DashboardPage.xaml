<Page
    x:Class="TransactionMonitor.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24">

            <TextBlock Text="Панель управления"
                       Style="{StaticResource TitleLargeTextBlockStyle}"/>

            <TextBlock Text="Обзор системы мониторинга транзакций"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Клиенты" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalClientsText" Text="—" FontSize="32"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="BlockedClientsText" Text="заблокировано: —"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Транзакции" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalTransactionsText" Text="—" FontSize="32"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="всего операций"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Мошенничество" FontWeight="SemiBold"/>
                        <TextBlock x:Name="FraudCountText" Text="—" FontSize="32"
                                   Foreground="OrangeRed"/>
                        <TextBlock Text="выявлено случаев"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Заблокировано" FontWeight="SemiBold"/>
                        <TextBlock x:Name="BlockedText" Text="—" FontSize="32"
                                   Foreground="Crimson"/>
                        <TextBlock Text="клиентов"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Последние транзакции" FontSize="20" FontWeight="SemiBold"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <ListView x:Name="RecentTransactionsList" Padding="8">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,4" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding TransactionID}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SenderName}"/>
                                <TextBlock Grid.Column="2" Padding="10,0,0,0" Text="{Binding AmountFormatted}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="{Binding Status}"/>
                                <TextBlock Grid.Column="4" Text="{Binding RiskLevel}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>