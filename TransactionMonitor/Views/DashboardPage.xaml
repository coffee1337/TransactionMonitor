<Page
    x:Class="TransactionMonitor.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel x:Name="RootPanel" Padding="32" Spacing="24" Opacity="0">

            <StackPanel.Resources>
                <Storyboard x:Name="FadeInStoryboard">
                    <DoubleAnimation
                        Storyboard.TargetName="RootPanel"
                        Storyboard.TargetProperty="Opacity"
                        From="0" To="1" Duration="0:0:0.4"/>
                    <DoubleAnimation
                        Storyboard.TargetName="RootPanelTranslate"
                        Storyboard.TargetProperty="Y"
                        From="20" To="0" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </StackPanel.Resources>

            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="RootPanelTranslate"/>
            </StackPanel.RenderTransform>

            <!-- Заголовок -->
            <StackPanel Spacing="4">
                <TextBlock Text="Дашборд" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Обзор системы мониторинга транзакций"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14"/>
            </StackPanel>

            <!-- Строка 1 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Клиенты -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Клиенты" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalClientsText" Text="—" FontSize="32" FontWeight="Bold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="BlockedClientsText" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE77B;" FontSize="28"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Top" Opacity="0.4"/>
                    </Grid>
                </Border>

                <!-- Транзакции -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Транзакции" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalTransactionsText" Text="—" FontSize="32" FontWeight="Bold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="TotalAmountText" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE8AB;" FontSize="28"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Top" Opacity="0.4"/>
                    </Grid>
                </Border>

                <!-- Мошенничество -->
                <Border Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Мошенничество" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="FraudCountText" Text="—" FontSize="32" FontWeight="Bold"
                                       Foreground="#F44336"/>
                            <TextBlock x:Name="UnreviewedText" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE7BA;" FontSize="28"
                                  Foreground="#F44336"
                                  VerticalAlignment="Top" Opacity="0.4"/>
                    </Grid>
                </Border>

                <!-- Средний риск -->
                <Border Grid.Column="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Средний риск" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="AvgRiskText" Text="—" FontSize="32" FontWeight="Bold"/>
                            <ProgressBar x:Name="AvgRiskBar" Minimum="0" Maximum="100" Height="6"
                                         CornerRadius="3"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE9D9;" FontSize="28"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Top" Opacity="0.4"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Строка 2 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Счета" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalAccountsText" Text="—" FontSize="32" FontWeight="Bold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="ActiveAccountsText" FontSize="12" Foreground="#4CAF50"/>
                                <TextBlock x:Name="FrozenAccountsText" FontSize="12" Foreground="#FF9800"/>
                            </StackPanel>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE8C7;" FontSize="28"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Top" Opacity="0.4"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Контрагенты" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalCounterpartiesText" Text="—" FontSize="32" FontWeight="Bold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="BlacklistedText" FontSize="12" Foreground="#F44336"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE731;" FontSize="28"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Top" Opacity="0.4"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Распределение рисков -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE9D9;" FontSize="18"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Распределение рисков" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel x:Name="RiskBarsPanel" Spacing="10"/>
                </StackPanel>
            </Border>

            <!-- Последние транзакции -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8AB;" FontSize="18"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Последние транзакции" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Grid Padding="8,8"
                          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                          CornerRadius="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Padding="16,0,0,0" Text="ID" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Padding="25,0,0,0" Text="Отправитель" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Padding="0,0,0,0" Text="Сумма" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Padding="15,0,0,0" Text="Тип" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="4" Padding="0,0,25,0" Text="Риск" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </Grid>

                    <ListView x:Name="RecentTransactionsList"
                              SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,10" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding IdText}"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SenderName}"
                                               VerticalAlignment="Center" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AmountFormatted}"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock TextAlignment="Center" Grid.Column="3" Text="{Binding TransactionType}"
                                               VerticalAlignment="Center" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <Border Grid.Column="4"
                                            Background="{Binding RiskBackground}"
                                            CornerRadius="4" Padding="8,3"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding RiskLevel}" FontSize="11"
                                                   Foreground="{Binding RiskForeground}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>