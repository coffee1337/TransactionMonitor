<Page
    x:Class="TransactionMonitor.Views.CounterpartiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Контрагенты" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Управление контрагентами и их риск-профилем"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="AddCounterpartyButton" Content="Добавить контрагента"
                    Click="AddCounterparty_Click"
                    VerticalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0"
                     PlaceholderText="Поиск по названию, ИНН..."
                     TextChanged="SearchBox_TextChanged"/>
            <ComboBox x:Name="BlacklistFilter" Grid.Column="1"
                      PlaceholderText="Чёрный список" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="В чёрном списке"/>
                <ComboBoxItem Content="Не в списке"/>
            </ComboBox>
            <TextBlock x:Name="CountText" Grid.Column="2"
                       Text="Всего: 0" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="16,12"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Padding="17,0,0,0" Text="ID" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Padding="23,0,0,0" Text="Название" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="2" Padding="6,0,0,0" Text="ИНН" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="Категория" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="4" Padding="0,0,25,0" Text="Риск" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Padding="0,0,15,0" Text="ЧС" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Text="Страна" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>

            <ListView x:Name="CounterpartiesList" Grid.Row="1"
                      IsItemClickEnabled="True"
                      ItemClick="CounterpartiesList_ItemClick"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,12" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding IdText}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding TaxID}"
                                       VerticalAlignment="Center" FontFamily="Consolas"/>
                            <TextBlock Grid.Column="3" Padding="1,0,0,0" Text="{Binding ActivityCategory}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Column="4" Background="{Binding RiskBg}"
                                    CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding RiskLevel}" FontSize="11"
                                           Foreground="{Binding RiskFg}"/>
                            </Border>
                            <Border Grid.Column="5" Background="{Binding BlacklistBg}"
                                    CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding BlacklistText}" FontSize="11"
                                           Foreground="{Binding BlacklistFg}"/>
                            </Border>
                            <TextBlock Grid.Column="6" Text="{Binding CountryOfRegistry}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>