<Page
    x:Class="TransactionMonitor.Views.CounterpartiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Контрагенты" FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="Управление контрагентами и их риск-профилем"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Поиск и фильтры -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="Поиск по названию, ИНН..."
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="BlacklistFilter"
                      Grid.Column="1"
                      PlaceholderText="Чёрный список"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="В чёрном списке"/>
                <ComboBoxItem Content="Не в списке"/>
            </ComboBox>

            <TextBlock x:Name="CountText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Таблица -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Шапка -->
                <Grid Grid.Row="0" Padding="16,12"
                      Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Название" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="ИНН" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Категория" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="Риск" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="Статус" FontWeight="SemiBold"/>
                </Grid>

                <!-- Список -->
                <ListView x:Name="CounterpartiesList"
                          Grid.Row="1"
                          SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,8" ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding CounterpartyID}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding TaxID}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="{Binding ActivityCategory}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Column="4"
                                        Background="{Binding RiskBackground}"
                                        CornerRadius="4" Padding="8,2"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding RiskLevel}"
                                               Foreground="{Binding RiskForeground}"
                                               FontSize="12"/>
                                </Border>
                                <Border Grid.Column="5"
                                        Background="{Binding BlacklistBackground}"
                                        CornerRadius="4" Padding="8,2"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding BlacklistText}"
                                               Foreground="{Binding BlacklistForeground}"
                                               FontSize="12"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>