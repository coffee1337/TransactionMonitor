<Page
    x:Class="TransactionMonitor.Views.TransactionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Spacing="4"
            Orientation="Horizontal">
            <StackPanel Spacing="4" HorizontalAlignment="Left">
                <TextBlock Text="Транзакции" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Мониторинг и управление транзакциями"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button x:Name="AddTransactionButton"
            Content="➕ Новая транзакция"
            Click="AddTransaction_Click"
            VerticalAlignment="Center"
            Margin="32,0,0,0"
            Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>

        <!-- Фильтры -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="Поиск по клиенту, описанию..."
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="StatusFilter"
                      Grid.Column="1"
                      PlaceholderText="Статус"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                <ComboBoxItem Content="Completed"/>
                <ComboBoxItem Content="Rejected"/>
                <ComboBoxItem Content="Processing"/>
            </ComboBox>

            <ComboBox x:Name="RiskFilter"
                      Grid.Column="2"
                      PlaceholderText="Уровень риска"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все уровни" IsSelected="True"/>
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
                <ComboBoxItem Content="Critical"/>
            </ComboBox>

            <TextBlock x:Name="CountText"
                       Grid.Column="3"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Таблица -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Шапка -->
                <Grid Grid.Row="0" Padding="16,12"
                      Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Клиент" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Сумма" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Дата" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="Тип" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="Статус" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="6" Text="Риск" FontWeight="SemiBold"/>
                </Grid>

                <!-- Список -->
                <ListView x:Name="TransactionsList"
                          Grid.Row="1"
                          SelectionMode="Single"
                          ItemClick="TransactionsList_ItemClick"
                          IsItemClickEnabled="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,8" ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding TransactionID}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SenderName}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding AmountFormatted}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="{Binding DateFormatted}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="{Binding TransactionType}"/>
                                <Border Grid.Column="5"
                                        Background="{Binding StatusBackground}"
                                        CornerRadius="4" Padding="8,2"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="{Binding StatusForeground}"
                                               FontSize="12"/>
                                </Border>
                                <Border Grid.Column="6"
                                        Background="{Binding RiskBackground}"
                                        CornerRadius="4" Padding="8,2"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding RiskLevel}"
                                               Foreground="{Binding RiskForeground}"
                                               FontSize="12"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>