<Page
    x:Class="TransactionMonitor.Views.TransactionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Транзакции" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Мониторинг и управление транзакциями"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Новая транзакция"
                    Click="AddTransaction_Click"
                    VerticalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox" Grid.Column="0"
                     PlaceholderText="Поиск по клиенту, описанию..."
                     TextChanged="SearchBox_TextChanged"/>
            <ComboBox x:Name="StatusFilter" Grid.Column="1"
                      PlaceholderText="Статус" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                <ComboBoxItem Content="Completed"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>
            <ComboBox x:Name="RiskFilter" Grid.Column="2"
                      PlaceholderText="Риск" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все уровни" IsSelected="True"/>
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
                <ComboBoxItem Content="Critical"/>
            </ComboBox>
            <TextBlock x:Name="CountText" Grid.Column="3"
                       Text="Всего: 0" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="16,12"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="Отправитель" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="2" Text="Контрагент" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="Сумма" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="4" Text="Тип" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="Статус" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Text="Риск" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
            </Grid>

            <ListView x:Name="TransactionsList" Grid.Row="1"
                      IsItemClickEnabled="True"
                      ItemClick="TransactionsList_ItemClick"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,12" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding IdText}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SenderName}"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding CounterpartyName}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="{Binding AmountFormatted}"
                                       VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="{Binding TransactionType}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Border Grid.Column="5" Background="{Binding StatusBg}"
                                    CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Status}" FontSize="11"
                                           Foreground="{Binding StatusFg}"/>
                            </Border>
                            <Border Grid.Column="6" Background="{Binding RiskBg}"
                                    CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding RiskLevel}" FontSize="11"
                                           Foreground="{Binding RiskFg}"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>