<Page
    x:Class="TransactionMonitor.Views.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <NavigationView
        x:Name="NavView"
        PaneDisplayMode="Left"
        IsSettingsVisible="False"
        SelectionChanged="NavView_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem Tag="dashboard" Content="Дашборд">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="clients" Content="Клиенты">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="People"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="accounts" Content="Счета">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Library"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="transactions" Content="Транзакции">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Switch"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="counterparties" Content="Контрагенты">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Shop"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="risks" Content="Оценки риска">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Flag"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="labels" Content="Метки риска">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Tag"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="reports" Content="Отчёты">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Document"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="calculator" Content="ML-калькулятор">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Calculator"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="charts" Content="Графики">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Pictures"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Tag="logout" Content="Выйти">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="LeaveChat"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка с пользователем -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PageTitle"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="16" FontWeight="SemiBold"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="12">
                        <Border x:Name="RoleBadge"
                                CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="RoleText" FontSize="12"/>
                        </Border>
                        <TextBlock x:Name="UserNameText"
                                   VerticalAlignment="Top"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="ContentFrame" Grid.Row="1"/>
        </Grid>
    </NavigationView>
</Page>