<Page
    x:Class="TransactionMonitor.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Левая панель — декоративная -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть с описанием -->
        <Border Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="24"
                        Padding="48">

                <Border Width="80" Height="80"
                        CornerRadius="20"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource AccentAAFillColorDefaultBrush}">
                    <TextBlock Text="🛡️" FontSize="40"
                               Padding="13,11,0,0"/>
                </Border>

                <TextBlock Text="TransactionMonitor"
                           FontSize="36" FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <TextBlock Text="Система мониторинга денежных&#x0a;транзакций с модулем&#x0a;машинного обучения"
                           FontSize="16"
                           LineHeight="28"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <StackPanel Spacing="16" Margin="0,16,0,0">

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock Text="📊" FontSize="18"
                                       Padding="6,5,0,0"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Аналитика в реальном времени"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Мониторинг всех транзакций"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock Text="🤖" FontSize="18"
                                       Padding="6,5,0,0"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ML-оценка риска"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Автоматическое выявление угроз"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock Text="👥" FontSize="18"
                                       Padding="6,2,0,0"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Ролевой доступ"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Администратор, аналитик, оператор"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Правая часть — форма входа -->
        <Grid Grid.Column="1">
            <StackPanel VerticalAlignment="Center"
                        Padding="48"
                        Spacing="24">

                <StackPanel Spacing="8">
                    <TextBlock Text="Добро пожаловать"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="Введите данные для входа в систему"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Spacing="16">

                    <StackPanel Spacing="6">
                        <TextBlock Text="Логин" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox x:Name="UsernameBox"
                                 PlaceholderText="Введите логин"
                                 Height="44"
                                 Padding="10,10,0,0"
                                 KeyDown="Input_KeyDown"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Пароль" FontWeight="SemiBold" FontSize="13"/>
                        <PasswordBox x:Name="PasswordBox"
                                     PlaceholderText="Введите пароль"
                                     Height="44"
                                     Padding="10,10,0,0"
                                     KeyDown="Input_KeyDown"/>
                    </StackPanel>

                    <!-- Ошибка -->
                    <Border x:Name="ErrorBorder"
                            Visibility="Collapsed"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚠️" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ErrorText"
                                       Text="Неверный логин или пароль"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Войти в систему"
                            Click="Login_Click"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="44"
                            FontSize="14"/>
                </StackPanel>

                <!-- Подсказки аккаунтов -->
                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Демо-аккаунты"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0"
                                    Background="#3D1A1A"
                                    CornerRadius="3" Padding="6,2">
                                <TextBlock Text="Админ" FontSize="11"
                                           Padding="8,0,0,2"
                                           Foreground="#FF6B6B"/>
                            </Border>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="admin / admin123"
                                       FontSize="12" FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Border Grid.Row="1" Grid.Column="0"
                                    Margin="0,6,0,0"
                                    Background="#3D3200"
                                    CornerRadius="3" Padding="6,2">
                                <TextBlock Text="Аналитик" FontSize="11"
                                           Padding="1,0,0,2"
                                           Foreground="#FFD700"/>
                            </Border>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Margin="0,6,0,0"
                                       Text="analyst / analyst123"
                                       FontSize="12" FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Border Grid.Row="2" Grid.Column="0"
                                    Margin="0,6,0,0"
                                    Background="#1A3D1A"
                                    CornerRadius="3" Padding="6,2">
                                <TextBlock Text="Оператор" FontSize="11"
                                           Padding="1,0,0,2"
                                           Foreground="#6BFF6B"/>
                            </Border>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Margin="0,6,0,0"
                                       Text="operator / operator123"
                                       FontSize="12" FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</Page>