<Page
    x:Class="TransactionMonitor.Views.AccountsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <StackPanel Spacing="4" HorizontalAlignment="Left">
                <TextBlock Text="Счета" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Управление банковскими счетами"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button x:Name="ExportButton"
                    Content="📥 Экспорт"
                    Click="Export_Click"
                    VerticalAlignment="Center"
                    Margin="32,0,0,0"/>
        </StackPanel>

        <!-- Статистика -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Всего счетов" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalText" Text="—" FontSize="32"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Активные" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ActiveText" Text="—" FontSize="32"
                               Foreground="#4CAF50"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Замороженные" FontWeight="SemiBold"/>
                    <TextBlock x:Name="FrozenText" Text="—" FontSize="32"
                               Foreground="#FF9800"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Общий баланс" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalBalanceText" Text="—" FontSize="22"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Фильтры -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="Поиск по номеру счёта, клиенту..."
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="StatusFilter"
                      Grid.Column="1"
                      PlaceholderText="Статус"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Frozen"/>
                <ComboBoxItem Content="Closed"/>
            </ComboBox>

            <ComboBox x:Name="TypeFilter"
                      Grid.Column="2"
                      PlaceholderText="Тип счёта"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все типы" IsSelected="True"/>
                <ComboBoxItem Content="Debit"/>
                <ComboBoxItem Content="Credit"/>
                <ComboBoxItem Content="Savings"/>
                <ComboBoxItem Content="Corporate"/>
            </ComboBox>

            <TextBlock x:Name="CountText"
                       Grid.Column="3"
                       Text="Всего: 0"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Список счетов -->
        <ListView x:Name="AccountsList"
                  Grid.Row="3"
                  IsItemClickEnabled="True"
                  ItemClick="AccountsList_ItemClick"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,16" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding IdText}"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Grid.Column="1" Text="{Binding AccountNumber}"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="2" Text="{Binding OwnerName}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="3" Text="{Binding BalanceFormatted}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding BalanceForeground}"/>

                        <Border Grid.Column="4"
                                Background="{Binding StatusBackground}"
                                CornerRadius="4" Padding="8,4"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="12"
                                       Foreground="{Binding StatusForeground}"/>
                        </Border>

                        <TextBlock Grid.Column="5" Text="{Binding AccountType}"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Grid.Column="6" Text="{Binding OpenDateFormatted}"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>