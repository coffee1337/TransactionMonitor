<Page
    x:Class="TransactionMonitor.Views.RiskScoresPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Оценки риска" Style="{StaticResource PageHeaderStyle}"/>
                <TextBlock Text="ML-оценка риска транзакций" Style="{StaticResource PageSubheaderStyle}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressRing x:Name="ScanProgress" IsActive="False" Width="24" Height="24"
                              Visibility="Collapsed"/>
                <TextBlock x:Name="ScanStatusText" Text="" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                <Button x:Name="RescanButton" Content="Пересканировать все"
                        Click="Rescan_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Всего оценок" Style="{StaticResource PageSubheaderStyle}"/>
                    <TextBlock x:Name="TotalText" Text="—" FontSize="32" FontWeight="Bold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Мошенничество" Style="{StaticResource PageSubheaderStyle}"/>
                    <TextBlock x:Name="FraudText" Text="—" FontSize="32" FontWeight="Bold"
                               Foreground="#F44336"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Проверено" Style="{StaticResource PageSubheaderStyle}"/>
                    <TextBlock x:Name="ReviewedText" Text="—" FontSize="32" FontWeight="Bold"
                               Foreground="#4CAF50"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Критических" Style="{StaticResource PageSubheaderStyle}"/>
                    <TextBlock x:Name="CriticalText" Text="—" FontSize="32" FontWeight="Bold"
                               Foreground="#FF9800"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="RiskFilter" Grid.Column="0"
                      PlaceholderText="Уровень" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все уровни" IsSelected="True"/>
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
                <ComboBoxItem Content="Critical"/>
            </ComboBox>
            <ComboBox x:Name="FraudFilter" Grid.Column="1"
                      PlaceholderText="Мошенничество" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="Мошенничество"/>
                <ComboBoxItem Content="Норма"/>
            </ComboBox>
            <TextBlock x:Name="CountText" Grid.Column="2"
                       Text="" VerticalAlignment="Center" HorizontalAlignment="Right"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource TableHeaderStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Padding="20,0,0,0" Text="ID" Style="{StaticResource TableHeaderTextStyle}"/>
                <TextBlock Grid.Column="1" Padding="17,0,0,0" Text="Тр. ID" Style="{StaticResource TableHeaderTextStyle}"/>
                <TextBlock Grid.Column="2" Margin="32,0,200,0" Text="Клиент" Style="{StaticResource TableHeaderTextStyle}"/>
                <TextBlock Grid.Column="3" Margin="-20,0,75,0" Text="Скор" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Margin="-30,0,40,0" Text="Уровень" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Margin="0,0,57,0" Text="Фрод" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Margin="-10,0,30,0" Text="Проверен" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="7" Margin="0,0,30,0" Text="Дата" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Center"/>
            </Grid>

            <ListView x:Name="RiskScoresList" Grid.Row="1"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,10" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding IdText}"
                                       VerticalAlignment="Center" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TxIdText}"
                                       VerticalAlignment="Center" FontSize="13"/>
                            <TextBlock Grid.Column="2" Text="{Binding SenderName}"
                                       VerticalAlignment="Center" FontSize="13"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ScoreFormatted}" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <ProgressBar Value="{Binding ScoreValue}" Minimum="0" Maximum="100"
                                             Height="4" CornerRadius="2" Width="70"/>
                            </StackPanel>
                            <Border Grid.Column="4" Background="{Binding RiskBg}"
                                    CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding RiskLevel}" FontSize="11"
                                           Foreground="{Binding RiskFg}"/>
                            </Border>
                            <Border Grid.Column="5" Background="{Binding FraudBg}"
                                    CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding FraudText}" FontSize="11"
                                           Foreground="{Binding FraudFg}"/>
                            </Border>
                            <TextBlock Grid.Column="6" Text="{Binding ReviewedText}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontSize="12" Foreground="{Binding ReviewedForeground}"/>
                            <TextBlock Grid.Column="7" Text="{Binding DateFormatted}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>