<Page
    x:Class="TransactionMonitor.Views.RiskScoresPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Оценки риска" FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="ML-оценка риска транзакций"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Карточки статистики -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Всего оценок" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalText" Text="—" FontSize="32"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Мошенничество" FontWeight="SemiBold"/>
                    <TextBlock x:Name="FraudText" Text="—" FontSize="32"
                               Foreground="OrangeRed"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Проверено" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ReviewedText" Text="—" FontSize="32"
                               Foreground="MediumSeaGreen"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Критических" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CriticalText" Text="—" FontSize="32"
                               Foreground="Crimson"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Фильтры -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="RiskFilter"
                      Grid.Column="0"
                      PlaceholderText="Уровень риска"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все уровни" IsSelected="True"/>
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
                <ComboBoxItem Content="Critical"/>
            </ComboBox>

            <ComboBox x:Name="FraudFilter"
                      Grid.Column="1"
                      PlaceholderText="Мошенничество"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="Мошенничество"/>
                <ComboBoxItem Content="Норма"/>
            </ComboBox>

            <TextBlock x:Name="CountText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Таблица -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Шапка -->
                <Grid Grid.Row="0" Padding="16,12"
                      Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Тр-я" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Клиент" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Скор" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="Уровень" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="Fraud" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="6" Text="Проверено" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="7" Text="Дата" FontWeight="SemiBold"/>
                </Grid>

                <!-- Список -->
                <ListView x:Name="RiskScoresList"
                          Grid.Row="1"
                          SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,8" ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding ScoreID}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TransactionID}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding SenderName}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{Binding ScoreFormatted}"
                                           Foreground="{Binding RiskForeground}"
                                           FontWeight="SemiBold"/>
                                <Border Grid.Column="4"
                                        Background="{Binding RiskBackground}"
                                        CornerRadius="4" Padding="8,2"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding RiskLevel}"
                                               Foreground="{Binding RiskForeground}"
                                               FontSize="12"/>
                                </Border>
                                <Border Grid.Column="5"
                                        Background="{Binding FraudBackground}"
                                        CornerRadius="4" Padding="8,2"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding FraudText}"
                                               Foreground="{Binding FraudForeground}"
                                               FontSize="12"/>
                                </Border>
                                <TextBlock Grid.Column="6"
                                           Text="{Binding ReviewedText}"
                                           Foreground="{Binding ReviewedForeground}"/>
                                <TextBlock Grid.Column="7"
                                           Text="{Binding DateFormatted}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>