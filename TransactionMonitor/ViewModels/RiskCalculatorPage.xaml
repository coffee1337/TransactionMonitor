<Page
    x:Class="TransactionMonitor.Views.RiskCalculatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="32">
        <Grid ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка: форма ввода -->
            <StackPanel Grid.Column="0" Spacing="16">

                <TextBlock Text="ML-калькулятор риска"
                           FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Введите параметры транзакции для оценки риска"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">

                        <TextBlock Text="Параметры транзакции"
                                   FontSize="16" FontWeight="SemiBold"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Сумма транзакции (руб.)"/>
                            <NumberBox x:Name="AmountBox"
                                       Value="10000"
                                       Minimum="1"
                                       Maximum="99999999"
                                       SpinButtonPlacementMode="Inline"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Час совершения (0-23)"/>
                            <NumberBox x:Name="HourBox"
                                       Value="12"
                                       Minimum="0"
                                       Maximum="23"
                                       SpinButtonPlacementMode="Inline"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Транзакций за последние 24 часа"/>
                            <NumberBox x:Name="FreqBox"
                                       Value="1"
                                       Minimum="0"
                                       Maximum="100"
                                       SpinButtonPlacementMode="Inline"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Уровень риска контрагента"/>
                            <ComboBox x:Name="CounterpartyRiskBox" SelectedIndex="0"
                                      HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Low"/>
                                <ComboBoxItem Content="Medium"/>
                                <ComboBoxItem Content="High"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Скоринг клиента (0.0 - 1.0)"/>
                            <NumberBox x:Name="ScoringBox"
                                       Value="0.3"
                                       Minimum="0"
                                       Maximum="1"
                                       SmallChange="0.1"
                                       SpinButtonPlacementMode="Inline"/>
                        </StackPanel>

                        <ToggleSwitch x:Name="BlacklistSwitch"
                                      Header="Контрагент в чёрном списке"
                                      IsOn="False"/>

                        <ToggleSwitch x:Name="BlockedSwitch"
                                      Header="Клиент заблокирован"
                                      IsOn="False"/>

                        <Button Content="Рассчитать риск"
                                Click="Calculate_Click"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Правая колонка: результат -->
            <StackPanel Grid.Column="1" Spacing="16">

                <TextBlock Text="Результат оценки"
                           FontSize="32" FontWeight="Bold"
                           Foreground="Transparent"/>

                <Border x:Name="ResultCard"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">

                        <TextBlock Text="Нажмите 'Рассчитать риск'"
                                   x:Name="PlaceholderText"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <StackPanel x:Name="ResultPanel" Visibility="Collapsed" Spacing="16">

                            <TextBlock Text="Уровень риска" FontWeight="SemiBold"/>

                            <Border x:Name="RiskLevelBadge"
                                    CornerRadius="8" Padding="16,8"
                                    HorizontalAlignment="Left">
                                <TextBlock x:Name="RiskLevelText"
                                           FontSize="24" FontWeight="Bold"/>
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Риск-скор" FontWeight="SemiBold"/>
                                <ProgressBar x:Name="RiskProgressBar"
                                             Minimum="0" Maximum="100"
                                             Height="12"/>
                                <TextBlock x:Name="RiskScoreText"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <TextBlock Text="Факторы риска" FontWeight="SemiBold"/>

                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="8" Padding="16">
                                <ItemsControl x:Name="FactorsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Margin="0,4"
                                                       TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <TextBlock x:Name="RecommendationText"
                                       TextWrapping="Wrap"
                                       FontStyle="Italic"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>